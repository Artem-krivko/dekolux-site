---
import { site } from "../data/site";
---
<header class="sticky top-0 z-50 border-b border-slate-200 bg-white/95 backdrop-blur">
  <div class="mx-auto flex max-w-7xl items-center justify-between px-6 py-4">
    <a href="/" class="text-2xl font-extrabold tracking-tight transition hover:opacity-80">
  <span class="text-[var(--text-main)]">DEKO</span><span style="color: var(--color-accent);">LUX</span>
</a>

    <nav class="hidden items-center gap-6 text-sm font-medium text-slate-700 md:flex">
      <a href="/" class="transition hover:opacity-80">Главная</a>
      <a href="/gnb-prokol" class="transition hover:opacity-80">Прокол под дорогой</a>
      <a href="/arenda-mini-ekskavatora" class="transition hover:opacity-80">
        Аренда мини-экскаватора
      </a>
      <a href="/kanalizaciya-septiki" class="transition hover:opacity-80">
        Канализация и септики
      </a>
      <a href="/contacts" class="transition hover:opacity-80">Контакты</a>
    </nav>

    <div class="flex items-center gap-3">
      <a
        href="/contacts"
        class="hidden rounded-full px-5 py-3 text-sm font-semibold text-white transition md:inline-flex"
        style="background-color: var(--color-accent);"
      >
        Получить расчёт
      </a>

      <button
        id="menu-toggle"
        class="inline-flex h-11 w-11 items-center justify-center rounded-full border border-slate-200 text-[var(--text-main)] md:hidden"
        type="button"
        aria-label="Открыть меню"
        aria-expanded="false"
        aria-controls="mobile-menu"
      >
        <svg
          id="menu-open-icon"
          xmlns="http://www.w3.org/2000/svg"
          class="h-5 w-5"
          fill="none"
          viewBox="0 0 24 24"
          stroke="currentColor"
          stroke-width="2"
        >
          <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16" />
        </svg>

        <svg
          id="menu-close-icon"
          xmlns="http://www.w3.org/2000/svg"
          class="hidden h-5 w-5"
          fill="none"
          viewBox="0 0 24 24"
          stroke="currentColor"
          stroke-width="2"
        >
          <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
        </svg>
      </button>
    </div>
  </div>

  <div id="mobile-menu" class="hidden border-t border-slate-200 bg-white md:hidden">
    <nav class="mx-auto flex max-w-7xl flex-col px-6 py-4 text-base font-medium text-[var(--text-main)]">
      <a href="/" class="rounded-xl px-3 py-3 transition hover:bg-slate-50">Главная</a>
      <a href="/gnb-prokol" class="rounded-xl px-3 py-3 transition hover:bg-slate-50">
        Прокол под дорогой / ГНБ
      </a>
      <a
        href="/arenda-mini-ekskavatora"
        class="rounded-xl px-3 py-3 transition hover:bg-slate-50"
      >
        Аренда мини-экскаватора
      </a>
      <a
        href="/kanalizaciya-septiki"
        class="rounded-xl px-3 py-3 transition hover:bg-slate-50"
      >
        Канализация и септики
      </a>
      <a href="/contacts" class="rounded-xl px-3 py-3 transition hover:bg-slate-50">Контакты</a>

      <a
        href="/contacts"
        class="mt-3 inline-flex items-center justify-center rounded-full px-5 py-3 text-sm font-semibold text-white"
        style="background-color: var(--color-accent);"
      >
        Получить расчёт
      </a>
    </nav>
  </div>
</header>

<script>
  const menuToggle = document.getElementById("menu-toggle");
  const mobileMenu = document.getElementById("mobile-menu");
  const openIcon = document.getElementById("menu-open-icon");
  const closeIcon = document.getElementById("menu-close-icon");

  if (menuToggle && mobileMenu && openIcon && closeIcon) {
    menuToggle.addEventListener("click", () => {
      const isHidden = mobileMenu.classList.contains("hidden");

      mobileMenu.classList.toggle("hidden");
      openIcon.classList.toggle("hidden");
      closeIcon.classList.toggle("hidden");

      menuToggle.setAttribute("aria-expanded", String(isHidden));
    });
  }
</script>