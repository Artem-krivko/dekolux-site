---
const siteUrl = "https://dekolux.by";

const localBusinessSchema = {
  "@context": "https://schema.org",
  "@type": "LocalBusiness",
  name: "Dekolux",
  url: siteUrl,
  telephone: "+375296326650",
  email: "dekolux@internet.ru",
  areaServed: "Могилёв и Могилёвская область",
  description:
    "Прокол под дорогой (ГНБ), аренда мини-экскаватора, наружная канализация и монтаж септиков в Могилёве и Могилёвской области",
  address: {
    "@type": "PostalAddress",
    addressLocality: "Могилёв",
    addressCountry: "BY"
  }
};
---

<!doctype html>
<html lang="ru">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={siteUrl} />
    <meta property="og:image" content={`${siteUrl}/og-cover.jpg`} />

    <!-- Schema.org LocalBusiness -->
    <script type="application/ld+json">
      {JSON.stringify(localBusinessSchema)}
    </script>

    <slot name="head" />
  </head>

  <body>
    <slot />
  </body>
</html>

<style>
  html,
  body {
    margin: 0;
    width: 100%;
    height: 100%;
  }
</style>