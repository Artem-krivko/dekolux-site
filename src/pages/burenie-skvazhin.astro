    const seoMoreDrilling = document.getElementById("seo-more-drilling");

    if (seoToggleDrilling && seoMoreDrilling) {
      seoToggleDrilling.addEventListener("click", () => {
        const isHidden = seoMoreDrilling.classList.contains("hidden");
        seoMoreDrilling.classList.toggle("hidden");
        seoToggleDrilling.textContent = isHidden ? "Свернуть" : "Читать дальше";
