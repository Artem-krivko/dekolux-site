---
import MainLayout from "../layouts/MainLayout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";

const title = "Бурение скважин на воду в Могилёве — цены и выезд | Dekolux";
const description =
  "Бурение скважин на воду в Могилёве и Могилёвской области. Водоснабжение частных домов и объектов. Собственная техника, выезд по области. Звоните.";

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "Какая глубина скважины на воду в Могилёвской области?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Глубина скважины зависит от геологии участка. В Могилёвской области водоносный горизонт обычно находится на глубине от 20 до 80 метров. Точная глубина определяется после геологической оценки."
      }
    },
    {
      "@type": "Question",
      "name": "Сколько стоит бурение скважины на воду?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Стоимость бурения скважины — от 70 руб за метр. Итоговая цена зависит от глубины и типа грунта."
      }
    },
    {
      "@type": "Question",
      "name": "Как долго служит скважина на воду?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "При правильном обустройстве и обслуживании скважина служит 20–50 лет. Срок зависит от типа скважины, материала обсадных труб и условий эксплуатации."
      }
    }
  ]
};

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: [
    {
      "@type": "ListItem",
      position: 1,
      name: "Главная",
      item: "https://www.dekolux.by/"
    },
    {
      "@type": "ListItem",
      position: 2,
      name: "Бурение скважин на воду",
      item: "https://www.dekolux.by/burenie-skvazhin"
    }
  ]
};
---

<MainLayout title={title} description={description}>
  <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
  <Header />

  <nav class="mx-auto max-w-7xl px-6 pt-6 text-sm text-slate-500">
    <a href="/" class="hover:text-slate-700">Главная</a>
    <span class="mx-2">/</span>
    <span class="text-slate-700">Бурение скважин на воду</span>
  </nav>

  <main>
    <section class="relative overflow-hidden bg-gradient-to-br from-[#0f1b30] via-[#12223c] to-[#0c1628] text-[var(--text-light)]">
      <div class="pointer-events-none absolute inset-0">
        <div class="absolute -left-20 top-10 h-72 w-72 rounded-full bg-blue-500/10 blur-3xl"></div>
        <div class="absolute right-0 top-0 h-80 w-80 rounded-full bg-orange-500/10 blur-3xl"></div>
        <div class="absolute bottom-0 left-1/3 h-64 w-64 rounded-full bg-cyan-400/5 blur-3xl"></div>
      </div>

      <div class="relative mx-auto max-w-7xl px-6 py-24 md:py-28">
        <div class="max-w-4xl">
          <div
            class="mb-6 inline-flex rounded-full border px-4 py-2 text-sm font-medium"
            style="
              border-color: color-mix(in srgb, var(--color-accent) 30%, transparent);
              background-color: color-mix(in srgb, var(--color-accent) 10%, transparent);
              color: #fed7aa;
            "
          >
            Услуга №5 • Могилёв и Могилёвская область
          </div>
        </div>
        <h1 class="max-w-4xl text-4xl font-extrabold leading-[1.05] tracking-tight md:text-6xl">
          Бурение скважин на воду
          <span style="color: var(--color-accent);">в Могилёве</span>
        </h1>

        <p class="mt-6 max-w-3xl text-lg leading-8 text-[var(--text-light)]/80">
          Бурение скважин для водоснабжения частных домов и объектов в Могилёве и области.
          Собственная техника, выезд по всей Могилёвской области.
        </p>

        <div class="mt-10 flex flex-col gap-4 sm:flex-row">
          <a
            href="/contacts"
            class="rounded-full px-6 py-4 text-center text-base font-semibold text-white shadow-lg transition duration-300 hover:-translate-y-0.5 hover:scale-[1.02]"
            style="background-color: var(--color-accent);"
          >
            Получить расчёт
          </a>

          <a
            href="tel:+375293326650"
            class="rounded-full border border-white/15 bg-white/5 px-6 py-4 text-center text-base font-semibold text-[var(--text-light)] backdrop-blur transition duration-300 hover:border-white/30 hover:bg-white/10"
          >
            Уточнить стоимость
          </a>
        </div>
      </div>
    </section>

    <section class="bg-white">
      <div class="mx-auto max-w-7xl px-6 py-24 md:py-28">
        <div class="grid gap-6 md:grid-cols-3">
          <div class="rounded-3xl border border-slate-200 bg-slate-50 p-6 shadow-sm transition duration-300 hover:-translate-y-0.5 hover:shadow-md">
            <div class="text-2xl font-extrabold text-[var(--text-main)]">от 70 руб</div>
            <p class="mt-2 text-sm leading-6 text-[var(--text-muted)]">стоимость за метр бурения</p>
          </div>

          <div class="rounded-3xl border border-slate-200 bg-slate-50 p-6 shadow-sm transition duration-300 hover:-translate-y-0.5 hover:shadow-md">
            <div class="text-2xl font-extrabold text-[var(--text-main)]">20–80 м</div>
            <p class="mt-2 text-sm leading-6 text-[var(--text-muted)]">типичная глубина скважин в области</p>
          </div>

          <div class="rounded-3xl border border-slate-200 bg-slate-50 p-6 shadow-sm transition duration-300 hover:-translate-y-0.5 hover:shadow-md">
            <div class="text-2xl font-extrabold text-[var(--text-main)]">20–50 лет</div>
            <p class="mt-2 text-sm leading-6 text-[var(--text-muted)]">срок службы скважины</p>
          </div>
        </div>
      </div>
    </section>

    <section class="bg-white">
      <div class="mx-auto grid max-w-7xl gap-12 px-6 py-24 md:grid-cols-2 md:py-28">
        <div>
          <p
            class="text-sm font-semibold uppercase tracking-[0.2em]"
