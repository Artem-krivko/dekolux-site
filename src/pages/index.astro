            <a
              href="/gnb-prokol"
              class="group relative min-w-[88%] snap-start overflow-hidden rounded-[2rem] border border-slate-700 bg-gradient-to-br from-slate-800 to-slate-700 p-8 text-[var(--text-light)] shadow-xl transition duration-300 hover:-translate-y-1 hover:border-orange-400/40 hover:shadow-2xl"
            >
              <div
                class="pointer-events-none absolute inset-0 opacity-80"
                style="background: radial-gradient(circle at top right, color-mix(in srgb, var(--color-accent) 20%, transparent), transparent 45%);"
              ></div>

              <div class="relative">
                <div
