---
import MainLayout from "../layouts/MainLayout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";

const title = "Прокол под дорогой, ГНБ, мини-экскаватор и септики в Могилёве — Dekolux";
const description =
  "Прокол под дорогой, ГНБ, аренда мини-экскаватора, наружная канализация и монтаж септиков в Могилёве и Могилёвской области. Собственная техника, выезд на объект, работа по договору.";
---

<MainLayout title={title} description={description}>
  <Header />

  <main>
    <section class="relative overflow-hidden bg-gradient-to-br from-[#0f1b30] via-[#12223c] to-[#0c1628]">
      <div class="pointer-events-none absolute inset-0">
        <div class="hero-glow absolute -bottom-10 -right-10 h-56 w-56 rounded-full bg-orange-500/15 blur-3xl"></div>
        <div class="absolute -left-20 top-10 h-72 w-72 rounded-full bg-blue-500/10 blur-3xl"></div>
        <div class="absolute right-0 top-0 h-80 w-80 rounded-full bg-orange-500/10 blur-3xl"></div>
        <div class="absolute bottom-0 left-1/3 h-64 w-64 rounded-full bg-cyan-400/5 blur-3xl"></div>
      </div>

      <div class="relative mx-auto grid max-w-7xl grid-cols-1 items-center gap-14 px-6 py-24 md:grid-cols-2 md:gap-16 md:py-28">
        <div class="hero-fade-up">
          <span class="inline-flex rounded-full border border-orange-500/25 bg-white/5 px-4 py-1.5 text-sm text-orange-300 backdrop-blur">
            Могилёв и Могилёвская область
          </span>

          <h1 class="mt-6 max-w-2xl text-4xl font-extrabold leading-[1.05] tracking-tight text-white md:text-6xl">
            Прокол методом ГНБ
            и земляные работы
            в Могилёве и области
          </h1>

          <p class="mt-6 max-w-xl text-lg leading-8 text-slate-300">
            Выполняем монтаж септиков, наружную канализацию и услуги мини-экскаватора
            на собственной технике. Работаем аккуратно, с выездом на объект и по договору.
          </p>

          <div class="mt-8 flex flex-wrap gap-4">
            <a
              href="/contacts"
              class="rounded-full px-6 py-3.5 text-sm font-semibold text-white shadow-lg transition duration-300 hover:-translate-y-0.5 hover:scale-[1.02]"
              style="background-color: var(--color-accent);"
            >
              Получить расчёт
            </a>

            <a
              href="/gnb-prokol"
              class="rounded-full border border-white/15 bg-white/5 px-6 py-3.5 text-sm font-semibold text-white backdrop-blur transition duration-300 hover:border-white/30 hover:bg-white/10"
            >
              Подробнее об услуге
            </a>
          </div>

          <div class="mt-12 grid max-w-md grid-cols-2 gap-5">
            <div class="rounded-2xl border border-white/10 bg-white/5 p-5 backdrop-blur">
              <div class="text-2xl font-bold text-white">5+ лет</div>
              <div class="mt-1 text-sm text-slate-400">опыта работ</div>
            </div>

            <div class="rounded-2xl border border-white/10 bg-white/5 p-5 backdrop-blur">
              <div class="text-2xl font-bold text-white">от 100 руб</div>
              <div class="mt-1 text-sm text-slate-400">за метр прокола</div>
            </div>
          </div>
        </div>

        <div class="hero-fade-up relative">
          <div class="hero-card relative overflow-hidden rounded-[2rem] border border-white/10 bg-white/5 shadow-[0_20px_60px_rgba(0,0,0,0.45)] backdrop-blur">
            <img
              src="/images/hero/hero.webp"
              alt="Мини-экскаватор и инженерные коммуникации"
              loading="eager"
              class="hero-image h-[420px] w-full object-cover md:h-[520px]"
            />

            <div class="absolute inset-0 bg-gradient-to-t from-[#0f172a]/55 via-transparent to-transparent"></div>
          </div>

          <div class="absolute -left-6 bottom-12 rounded-xl border border-white/10 bg-[#14213b]/80 px-4 py-2.5 text-sm shadow-xl backdrop-blur">
