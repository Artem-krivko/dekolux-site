<script>
window.addEventListener("load", () => {
  document.querySelectorAll(".hero-fade-up").forEach((el, i) => {
    setTimeout(() => {
      el.classList.add("show");
    }, i * 450);
  });
});

const toggleBenefits = document.getElementById("toggle-benefits");
const moreBenefits = document.getElementById("more-benefits");

if (toggleBenefits && moreBenefits) {
  toggleBenefits.addEventListener("click", () => {
    const isHidden = moreBenefits.classList.contains("hidden");
    moreBenefits.classList.toggle("hidden");
    toggleBenefits.textContent = isHidden ? "Скрыть" : "Показать ещё";
  });
}

const reviewsTrack = document.getElementById("reviews-track");
const reviewsPrev = document.getElementById("reviews-prev");
const reviewsNext = document.getElementById("reviews-next");

if (reviewsTrack && reviewsPrev && reviewsNext) {
  let currentIndex = 0;
  const totalSlides = 3;

  const updateSlider = () => {
    const isDesktop = window.innerWidth >= 768;
    const offset = isDesktop ? currentIndex * 50 : currentIndex * 100;
    reviewsTrack.style.transform = `translateX(-${offset}%)`;
  };

  reviewsNext.addEventListener("click", () => {
    const isDesktop = window.innerWidth >= 768;
    const maxIndex = isDesktop ? 1 : totalSlides - 1;
    currentIndex = currentIndex >= maxIndex ? 0 : currentIndex + 1;
    updateSlider();
  });

  reviewsPrev.addEventListener("click", () => {
    const isDesktop = window.innerWidth >= 768;
    const maxIndex = isDesktop ? 1 : totalSlides - 1;
    currentIndex = currentIndex <= 0 ? maxIndex : currentIndex - 1;
    updateSlider();
  });

  window.addEventListener("resize", updateSlider);
  updateSlider();
}
</script>