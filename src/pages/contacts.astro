---
import MainLayout from "../layouts/MainLayout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";

const title = "Контакты — Dekolux";
const description =
  "Контакты Dekolux: прокол под дорогой, ГНБ, аренда мини-экскаватора, наружная канализация и монтаж септиков в Могилёве и области.";
---

<MainLayout title={title} description={description}>
  <Header />

  <main>
    <section class="relative overflow-hidden bg-gradient-to-br from-[#0f1b30] via-[#12223c] to-[#0c1628] text-[var(--text-light)]">
      <div class="pointer-events-none absolute inset-0">
        <div class="absolute -left-20 top-10 h-72 w-72 rounded-full bg-blue-500/10 blur-3xl"></div>
        <div class="absolute right-0 top-0 h-80 w-80 rounded-full bg-orange-500/10 blur-3xl"></div>
        <div class="absolute bottom-0 left-1/3 h-64 w-64 rounded-full bg-cyan-400/5 blur-3xl"></div>
      </div>

      <div class="relative mx-auto max-w-7xl px-6 py-24 md:py-28">
        <div class="max-w-4xl">
          <div
            class="mb-6 inline-flex rounded-full border px-4 py-2 text-sm font-medium"
            style="
              border-color: color-mix(in srgb, var(--color-accent) 30%, transparent);
              background-color: color-mix(in srgb, var(--color-accent) 10%, transparent);
              color: #fed7aa;
            "
          >
            Связь с нами • Могилёв и Могилёвская область
          </div>

          <h1 class="max-w-4xl text-4xl font-extrabold leading-[1.05] tracking-tight md:text-6xl">
            Контакты
            <span style="color: var(--color-accent);">Dekolux</span>
          </h1>

          <p class="mt-6 max-w-3xl text-lg leading-8 text-[var(--text-light)]/80">
            Свяжитесь с нами удобным способом: по телефону, в мессенджерах или через форму.
            Поможем рассчитать стоимость и подскажем подходящее решение по вашему объекту.
          </p>
        </div>
      </div>
    </section>

    <section class="bg-white">
      <div class="mx-auto grid max-w-7xl gap-12 px-6 py-24 md:grid-cols-2 md:py-28">
        <div class="rounded-[2rem] border border-slate-200 bg-slate-50 p-8 shadow-sm">
          <p
            class="text-sm font-semibold uppercase tracking-[0.2em]"
            style="color: var(--color-accent);"
          >
            Контактная информация
          </p>

          <div class="mt-8 grid gap-4">
            <div class="rounded-[1.5rem] border border-slate-200 bg-white p-6 transition duration-300 hover:-translate-y-0.5 hover:shadow-md">
              <h2 class="text-lg font-bold text-[var(--text-main)]">Телефон</h2>
              <a
                href="tel:+375296326650"
                class="mt-2 inline-block text-base text-[var(--text-muted)] transition hover:opacity-80"
              >
                +375 (29) 632-66-50
              </a>
            </div>

            <div class="rounded-[1.5rem] border border-slate-200 bg-white p-6 transition duration-300 hover:-translate-y-0.5 hover:shadow-md">
              <h2 class="text-lg font-bold text-[var(--text-main)]">Мессенджеры</h2>

              <div class="mt-3 flex flex-col gap-2 text-base text-[var(--text-muted)]">
                <a
                  href="https://wa.me/375296326650"
                  target="_blank"
                  rel="noopener noreferrer"
                  class="transition hover:opacity-70"
                >
                  WhatsApp
                </a>

                <a
                  href="https://t.me/+375296326650"
                  target="_blank"
                  rel="noopener noreferrer"
                  class="transition hover:opacity-70"
                >
                  Telegram
                </a>

                <a
                  href="viber://chat?number=%2B375296326650"
                  class="transition hover:opacity-70"
                >
                  Viber
                </a>
              </div>
            </div>

            <div class="rounded-[1.5rem] border border-slate-200 bg-white p-6 transition duration-300 hover:-translate-y-0.5 hover:shadow-md">
              <h2 class="text-lg font-bold text-[var(--text-main)]">Email</h2>
              <a
                href="mailto:dekolux@internet.ru"
                class="mt-2 inline-block text-base text-[var(--text-muted)] transition hover:opacity-70"
              >
                dekolux@internet.ru
              </a>
            </div>

            <div class="rounded-[1.5rem] border border-slate-200 bg-white p-6 transition duration-300 hover:-translate-y-0.5 hover:shadow-md">
              <h2 class="text-lg font-bold text-[var(--text-main)]">Регион работы</h2>
              <p class="mt-2 text-base text-[var(--text-muted)]">
                Могилёв и Могилёвская область
              </p>
            </div>

            <div class="rounded-[1.5rem] border border-slate-200 bg-white p-6 transition duration-300 hover:-translate-y-0.5 hover:shadow-md">
              <h2 class="text-lg font-bold text-[var(--text-main)]">Формат работы</h2>
              <p class="mt-2 text-base text-[var(--text-muted)]">
                Консультация, расчёт стоимости, выезд на объект, работа по договору
              </p>
            </div>
          </div>
        </div>

        <div class="rounded-[2rem] border border-slate-200 bg-white p-8 shadow-sm">
          <p
            class="text-sm font-semibold uppercase tracking-[0.2em]"
            style="color: var(--color-accent);"
          >
            Заявка
          </p>

          <h2 class="mt-4 text-3xl font-extrabold text-[var(--text-main)] md:text-4xl">
            Оставьте запрос
          </h2>

          <p class="mt-4 max-w-2xl text-base leading-8 text-[var(--text-muted)]">
            Оставьте имя, телефон и короткое описание задачи. Мы свяжемся с вами и
            подскажем подходящее решение.
          </p>

          <form id="contact-form" class="mt-8 space-y-5">
            <input type="text" name="company" id="company" class="hidden" tabindex="-1" autocomplete="off" />

            <div class="flex flex-col gap-2">
              <label for="name" class="text-sm font-medium text-[var(--text-main)]">
                Имя
              </label>
              <input
                id="name"
                name="name"
                type="text"
                placeholder="Ваше имя"
                required
                class="w-full rounded-xl border border-slate-200 px-4 py-3 text-sm outline-none transition focus:border-slate-500 focus:ring-2 focus:ring-orange-400"
              />
            </div>

            <div class="flex flex-col gap-2">
              <label for="phone" class="text-sm font-medium text-[var(--text-main)]">
                Телефон
              </label>
              <input
                id="phone"
                name="phone"
                type="tel"
                placeholder="+375..."
                required
                class="w-full rounded-xl border border-slate-200 px-4 py-3 text-sm outline-none transition focus:border-slate-500 focus:ring-2 focus:ring-orange-400"
              />
            </div>

            <div class="flex flex-col gap-2">
              <label for="service" class="text-sm font-medium text-[var(--text-main)]">
                Услуга
              </label>
              <select
                id="service"
                name="service"
                class="w-full rounded-xl border border-slate-200 px-4 py-3 text-sm outline-none transition focus:border-slate-500 focus:ring-2 focus:ring-orange-400"
              >
                <option>Прокол под дорогой / ГНБ</option>
                <option>Аренда мини-экскаватора</option>
                <option>Канализация и септики</option>
                <option>Другая задача</option>
              </select>
            </div>

            <div class="flex flex-col gap-2">
              <label for="message" class="text-sm font-medium text-[var(--text-main)]">
                Комментарий
              </label>
              <textarea
                id="message"
                name="message"
                rows="4"
                placeholder="Кратко опишите задачу"
                class="w-full rounded-xl border border-slate-200 px-4 py-3 text-sm outline-none transition focus:border-slate-500 focus:ring-2 focus:ring-orange-400"
              ></textarea>
            </div>

            <div id="form-status" class="hidden rounded-xl border px-4 py-3 text-sm"></div>

            <button
              id="submit-button"
              type="submit"
              class="mt-3 inline-flex w-fit rounded-full px-6 py-3 text-sm font-semibold text-white transition duration-300 hover:-translate-y-0.5 hover:scale-[1.02] disabled:cursor-not-allowed disabled:opacity-70"
              style="background-color: var(--color-accent);"
            >
              Отправить заявку
            </button>
          </form>
        </div>
      </div>
    </section>

    <script is:inline>
      const form = document.getElementById("contact-form");
      const statusBox = document.getElementById("form-status");
      const submitButton = document.getElementById("submit-button");

      if (
        form instanceof HTMLFormElement &&
        statusBox instanceof HTMLElement &&
        submitButton instanceof HTMLButtonElement
      ) {
        form.addEventListener("submit", async (event) => {
          event.preventDefault();

          const formData = new FormData(form);
          const company = formData.get("company");

          if (company) return;

          const payload = {
            name: String(formData.get("name") || "").trim(),
            phone: String(formData.get("phone") || "").trim(),
            service: String(formData.get("service") || "").trim(),
            message: String(formData.get("message") || "").trim(),
          };

          if (!payload.name || !payload.phone) {
            statusBox.className =
              "rounded-xl border border-red-200 bg-red-50 px-4 py-3 text-sm text-red-700";
            statusBox.textContent = "Пожалуйста, заполните имя и телефон.";
            statusBox.classList.remove("hidden");
            return;
          }

          submitButton.disabled = true;
          submitButton.textContent = "Отправка...";

          try {
            const response = await fetch("/api/send", {
              method: "POST",
              headers: {
                "Content-Type": "application/json",
              },
              body: JSON.stringify(payload),
            });

            const data = await response.json().catch(() => null);

            if (!response.ok) {
              throw new Error(data?.error || "Ошибка отправки");
            }

            statusBox.className =
              "rounded-xl border border-emerald-200 bg-emerald-50 px-4 py-3 text-sm text-emerald-700";
            statusBox.textContent = "Заявка отправлена. Мы скоро с вами свяжемся.";
            statusBox.classList.remove("hidden");
            form.reset();
          } catch (error) {
            statusBox.className =
              "rounded-xl border border-red-200 bg-red-50 px-4 py-3 text-sm text-red-700";
            statusBox.textContent =
              error instanceof Error
                ? error.message
                : "Не удалось отправить заявку. Попробуйте ещё раз.";
            statusBox.classList.remove("hidden");
          } finally {
            submitButton.disabled = false;
            submitButton.textContent = "Отправить заявку";
          }
        });
      }
    </script>
  </main>

  <Footer />
</MainLayout>