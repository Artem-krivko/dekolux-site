---
export const prerender = true;

import MainLayout from "../../layouts/MainLayout.astro";
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";
import { cityPages } from "../../data/city-pages";

export async function getStaticPaths() {
  return cityPages.map((item) => ({
    params: { city: item.slug },
    props: { item },
  }));
}

const { item } = Astro.props;

const title = `Прокол под дорогой в ${item.cityTitle} (ГНБ) — от 80 руб | Dekolux`;
const description = `Прокол под дорогой в ${item.cityTitle} методом ГНБ. Без вскрытия асфальта. Прокладка труб и кабеля. Цена от 80 руб за метр.`;
const canonical = `https://www.dekolux.by/prokol-pod-dorogoy/${item.slug}`;

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: [
    {
      "@type": "ListItem",
      position: 1,
      name: "Главная",
      item: "https://www.dekolux.by/",
    },
    {
      "@type": "ListItem",
      position: 2,
      name: "Прокол под дорогой",
      item: "https://www.dekolux.by/gnb-prokol",
    },
    {
      "@type": "ListItem",
      position: 3,
      name: item.cityTitle,
      item: canonical,
    },
  ],
};

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: [
    {
      "@type": "Question",
      name: `Можно ли сделать прокол под дорогой в ${item.cityTitle} без вскрытия асфальта?`,
      acceptedAnswer: {
        "@type": "Answer",
        text: "Да, метод горизонтально направленного бурения позволяет проложить коммуникации под дорогой без вскрытия асфальта и разрушения покрытия.",
      },
    },
    {
      "@type": "Question",
      name: `Что можно проложить методом ГНБ в ${item.cityTitle}?`,
      acceptedAnswer: {
        "@type": "Answer",
        text: "Методом ГНБ можно прокладывать трубы водопровода, канализации, кабельные линии и другие подземные коммуникации.",
      },
    },
    {
      "@type": "Question",
      name: `От чего зависит цена прокола под дорогой в ${item.cityTitle}?`,
      acceptedAnswer: {
        "@type": "Answer",
        text: "Цена зависит от длины прокола, типа грунта, диаметра трубы или кабеля, сложности подъезда техники и условий на объекте.",
      },
    },
  ],
};
---

<MainLayout title={title} description={description}>
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />

  <Fragment slot="head">
    <link rel="canonical" href={canonical} />
    <meta property="og:url" content={canonical} />
  </Fragment>

  <Header />

  <nav class="mx-auto max-w-7xl px-6 pt-5 text-sm text-slate-500 md:pt-6">
    <a href="/" class="hover:text-slate-700">Главная</a>
    <span class="mx-2">/</span>
    <a href="/gnb-prokol" class="hover:text-slate-700">Прокол под дорогой</a>
    <span class="mx-2">/</span>
    <span class="text-slate-700">{item.cityTitle}</span>
  </nav>

  <main>
    <section class="relative overflow-hidden bg-gradient-to-br from-[#0f1b30] via-[#12223c] to-[#0c1628] text-[var(--text-light)]">
      <div class="pointer-events-none absolute inset-0">
        <div class="absolute -left-20 top-10 h-72 w-72 rounded-full bg-blue-500/10 blur-3xl"></div>
        <div class="absolute right-0 top-0 h-80 w-80 rounded-full bg-orange-500/10 blur-3xl"></div>
        <div class="absolute bottom-0 left-1/3 h-64 w-64 rounded-full bg-cyan-400/5 blur-3xl"></div>
      </div>

      <div class="relative mx-auto max-w-7xl px-6 py-16 sm:py-20 md:py-28">
        <div class="max-w-4xl">
          <div
            class="mb-6 inline-flex rounded-full border px-4 py-2 text-xs font-medium sm:text-sm"
            style="
              border-color: color-mix(in srgb, var(--color-accent) 30%, transparent);
              background-color: color-mix(in srgb, var(--color-accent) 10%, transparent);
              color: #fed7aa;
            "
          >
            {item.cityTitle} • Могилёвская область
          </div>

          <h1 class="max-w-4xl text-3xl font-extrabold leading-[1.05] tracking-tight sm:text-4xl md:text-6xl">
            Прокол под дорогой в
            <span style="color: var(--color-accent);">{item.cityTitle}</span>
          </h1>

          <p class="mt-6 max-w-3xl text-base leading-8 text-[var(--text-light)]/80 sm:text-lg">
            Выполняем прокол под дорогой методом ГНБ в {item.district}. Прокладываем
            трубы водопровода, канализации и кабельные линии без вскрытия асфальта
            и разрушения дорожного покрытия.
          </p>

          <div class="mt-8 flex flex-col gap-3 sm:flex-row sm:gap-4">
            <a
              href="/contacts"
              class="inline-flex items-center justify-center rounded-full px-6 py-4 text-center text-base font-semibold text-white transition duration-300 hover:-translate-y-0.5 hover:scale-[1.02]"
              style="background-color: var(--color-accent);"
            >
              Получить расчёт
            </a>

            <a
              href="tel:+375293326650"
              class="inline-flex items-center justify-center rounded-full border border-slate-700 px-6 py-4 text-center text-base font-semibold text-[var(--text-light)] transition duration-300 hover:border-slate-500 hover:bg-slate-800"
            >
              Позвонить: +375 (29) 332-66-50
            </a>
          </div>
        </div>
      </div>
    </section>

    <section class="bg-white">
      <div class="mx-auto max-w-7xl px-6 py-16 sm:py-20 md:py-24">
        <div class="grid gap-5 md:grid-cols-3 md:gap-6">
          <div class="rounded-[1.75rem] border border-slate-200 bg-slate-50 p-6 shadow-sm md:rounded-[2rem] md:p-8">
            <div class="text-xs font-semibold uppercase tracking-[0.2em] text-slate-500 sm:text-sm">
              Без вскрытия покрытия
            </div>
            <p class="mt-4 text-sm leading-7 text-[var(--text-muted)] sm:text-base sm:leading-8">
              Прокладываем коммуникации под дорогой без разрушения асфальта и благоустройства.
            </p>
          </div>

          <div class="rounded-[1.75rem] border border-slate-200 bg-slate-50 p-6 shadow-sm md:rounded-[2rem] md:p-8">
            <div class="text-xs font-semibold uppercase tracking-[0.2em] text-slate-500 sm:text-sm">
              Собственная техника
            </div>
            <p class="mt-4 text-sm leading-7 text-[var(--text-muted)] sm:text-base sm:leading-8">
              Работаем на собственной технике и быстро выезжаем на объект в {item.cityTitle}.
            </p>
          </div>

          <div class="rounded-[1.75rem] border border-slate-200 bg-slate-50 p-6 shadow-sm md:rounded-[2rem] md:p-8">
            <div class="text-xs font-semibold uppercase tracking-[0.2em] text-slate-500 sm:text-sm">
              Комплексный подход
            </div>
            <p class="mt-4 text-sm leading-7 text-[var(--text-muted)] sm:text-base sm:leading-8">
              Выполняем прокол, земляные работы, мини-экскаватор и прокладку коммуникаций.
            </p>
          </div>
        </div>
      </div>
    </section>

    <section class="bg-white">
  <div class="mx-auto max-w-7xl px-6 py-8 sm:py-10 md:py-12">
    <div class="rounded-[2rem] border border-slate-200 bg-slate-50 p-6 shadow-sm sm:p-8 md:p-10">
      <div class="grid gap-8 lg:grid-cols-[1.2fr_0.8fr] lg:items-center">
        <div>
          <p
            class="text-sm font-semibold uppercase tracking-[0.2em]"
            style="color: var(--color-accent);"
          >
            Стоимость в {item.cityTitle}
          </p>

          <h2 class="mt-4 text-2xl font-extrabold text-[var(--text-main)] sm:text-3xl md:text-4xl">
            Сколько стоит прокол под дорогой в {item.cityTitle}
          </h2>

          <p class="mt-4 text-base leading-8 text-[var(--text-muted)] sm:text-lg">
            Ориентировочная стоимость прокола под дорогой в {item.cityTitle}
            начинается от <strong class="text-[var(--text-main)]">80 руб за метр</strong>.
            Точная цена зависит от длины прокола, типа грунта, диаметра трубы,
            условий подъезда техники и сложности конкретного объекта.
          </p>

          <p class="mt-4 text-base leading-8 text-[var(--text-muted)] sm:text-lg">
            {item.priceNote}
          </p>

          <ul class="mt-6 space-y-3 text-sm leading-7 text-[var(--text-muted)] sm:text-base sm:leading-8">
            <li>• стоимость может быть выше или ниже в зависимости от условий объекта</li>
            <li>• учитывается длина прокола и особенности участка</li>
            <li>• точную цену сообщаем после уточнения задачи</li>
          </ul>
        </div>

        <div class="rounded-[1.75rem] border border-slate-200 bg-white p-6 shadow-sm sm:p-8">
          <div class="text-sm font-semibold uppercase tracking-[0.2em] text-slate-500">
            Ориентир по цене
          </div>

          <div class="mt-4 text-3xl font-extrabold sm:text-4xl" style="color: var(--color-accent);">
            от 80 руб / м
          </div>

          <p class="mt-4 text-sm leading-7 text-[var(--text-muted)] sm:text-base sm:leading-8">
            Рассчитаем стоимость под ваш объект в {item.cityTitle} и по Могилёвской области.
          </p>

          <div class="mt-6 flex flex-col gap-3">
            <a
              href="/contacts"
              class="inline-flex items-center justify-center rounded-full px-5 py-3 text-sm font-semibold text-white transition duration-300 hover:-translate-y-0.5 hover:scale-[1.02]"
              style="background-color: var(--color-accent);"
            >
              Получить расчёт
            </a>

            <a
              href="tel:+375293326650"
              class="inline-flex items-center justify-center rounded-full border border-slate-300 px-5 py-3 text-sm font-semibold text-[var(--text-main)] transition hover:border-slate-400 hover:bg-slate-50"
            >
              Позвонить
            </a>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

    <section class="bg-white">
      <div class="mx-auto max-w-4xl px-6 py-16 sm:py-20">
        <h2 class="text-2xl font-bold text-[var(--text-main)] md:text-3xl">
          Частые вопросы по ГНБ в {item.cityTitle}
        </h2>

        <div class="mt-8 space-y-4">
          <details class="group rounded-2xl border border-slate-200 bg-slate-50 p-5 sm:p-6">
            <summary class="flex cursor-pointer list-none items-center justify-between gap-4 text-base font-bold text-[var(--text-main)] md:text-lg">
              <span>Можно ли сделать прокол без вскрытия асфальта?</span>
              <span class="text-2xl leading-none text-[var(--color-accent)] transition duration-300 group-open:rotate-45">
                +
              </span>
            </summary>
            <p class="mt-4 text-sm leading-7 text-[var(--text-muted)] sm:text-base sm:leading-8">
              Да, метод ГНБ позволяет проложить коммуникации под дорогой без демонтажа покрытия.
            </p>
          </details>

          <details class="group rounded-2xl border border-slate-200 bg-slate-50 p-5 sm:p-6">
            <summary class="flex cursor-pointer list-none items-center justify-between gap-4 text-base font-bold text-[var(--text-main)] md:text-lg">
              <span>Что можно проложить под дорогой?</span>
              <span class="text-2xl leading-none text-[var(--color-accent)] transition duration-300 group-open:rotate-45">
                +
              </span>
            </summary>
            <p class="mt-4 text-sm leading-7 text-[var(--text-muted)] sm:text-base sm:leading-8">
              Водопровод, канализацию, электрический кабель и другие инженерные коммуникации.
            </p>
          </details>

          <details class="group rounded-2xl border border-slate-200 bg-slate-50 p-5 sm:p-6">
            <summary class="flex cursor-pointer list-none items-center justify-between gap-4 text-base font-bold text-[var(--text-main)] md:text-lg">
              <span>От чего зависит стоимость?</span>
              <span class="text-2xl leading-none text-[var(--color-accent)] transition duration-300 group-open:rotate-45">
                +
              </span>
            </summary>
            <p class="mt-4 text-sm leading-7 text-[var(--text-muted)] sm:text-base sm:leading-8">
              От длины прокола, типа грунта, диаметра трубы и условий на конкретном объекте.
            </p>
          </details>
        </div>
      </div>
    </section>

    <section class="bg-slate-50 py-16 sm:py-20">
      <div class="mx-auto max-w-4xl px-6">
        <h2 class="mb-6 text-2xl font-bold text-[var(--text-main)]">
          Прокол под дорогой в {item.cityTitle}
        </h2>

        <div class="space-y-6 text-base leading-8 text-slate-600 sm:text-lg">
          <p>
           Компания Dekolux выполняет прокол под дорогой в {item.district}
            методом горизонтально направленного бурения. Это надёжный способ
            проложить трубы и кабель под дорогой без вскрытия асфальта.
          </p>

          <p>
             {item.intro}
          </p>

          <p>
            {item.whyUsCity}
          </p>

          <div id={`seo-more-${item.slug}`} class="hidden space-y-6 md:block">
            <p>
              Мы выполняем прокладку водопровода, канализации, кабельных линий и
              других подземных коммуникаций. Работы проводятся аккуратно, быстро
              и с учётом условий конкретного объекта.
            </p>

            <p>
              Помимо ГНБ, компания Dekolux также предлагает
              <a href="/arenda-mini-ekskavatora" class="text-orange-500 hover:underline">
                аренду мини-экскаватора
              </a>
              и
              <a href="/kanalizaciya-septiki" class="text-orange-500 hover:underline">
                монтаж наружной канализации и септиков
              </a>
              в {item.cityTitle} и по Могилёвской области.
            </p>

            <p>
              Если вам нужен прокол под дорогой в {item.cityTitle}, свяжитесь с нами:
              мы подскажем по технологии, оценим объект и поможем подобрать подходящее решение.
            </p>
          </div>
        </div>

        <button
          id={`seo-toggle-${item.slug}`}
          type="button"
          class="mt-6 inline-flex rounded-full border border-slate-300 px-5 py-3 text-sm font-semibold text-[var(--text-main)] transition hover:border-slate-400 hover:bg-white md:hidden"
        >
          Читать дальше
        </button>
      </div>
    </section>

    <section class="bg-white">
  <div class="mx-auto max-w-7xl px-6 py-12 sm:py-14 md:py-16">
    <div class="rounded-[2rem] border border-slate-200 bg-slate-50 p-6 shadow-sm sm:p-8">
      <div class="max-w-3xl">
        <p
          class="text-sm font-semibold uppercase tracking-[0.2em]"
          style="color: var(--color-accent);"
        >
          Другие города
        </p>

        <h2 class="mt-4 text-2xl font-extrabold text-[var(--text-main)] md:text-3xl">
          Работаем и в других городах области
        </h2>

        <p class="mt-4 text-base leading-8 text-[var(--text-muted)]">
          Выполняем прокол под дорогой, ГНБ и сопутствующие работы
          не только в {item.cityTitle}, но и в других городах Могилёвской области.
        </p>
      </div>

      <div class="mt-8 flex flex-wrap gap-3">
        {cityPages
          .filter((cityItem) => cityItem.slug !== item.slug)
          .map((cityItem) => (
            <a
              href={`/prokol-pod-dorogoy/${cityItem.slug}`}
              class="rounded-full border border-slate-200 bg-white px-4 py-2 text-sm font-medium text-[var(--text-main)] transition hover:border-orange-400 hover:text-orange-500"
            >
              {cityItem.cityTitle}
            </a>
          ))}
      </div>
    </div>
  </div>
</section>

    <section class="bg-white">
      <div class="mx-auto max-w-7xl px-6 py-16 sm:py-20">
        <div class="rounded-[2rem] border border-slate-200 bg-slate-50 p-6 shadow-sm md:p-10">
          <div class="max-w-3xl">
            <p
              class="text-sm font-semibold uppercase tracking-[0.2em]"
              style="color: var(--color-accent);"
            >
              Получить консультацию
            </p>

            <h2 class="mt-4 text-2xl font-extrabold text-[var(--text-main)] md:text-4xl">
              Нужен прокол под дорогой в {item.cityTitle}?
            </h2>

            <p class="mt-4 text-base leading-8 text-[var(--text-muted)]">
              Свяжитесь с нами удобным способом. Подскажем по стоимости, срокам и
              возможностям выполнения работ на вашем объекте.
            </p>

            <div class="mt-8 flex flex-col gap-3 sm:flex-row sm:gap-4">
              <a
                href="/contacts"
                class="inline-flex items-center justify-center rounded-full px-6 py-4 text-center text-base font-semibold text-white transition duration-300 hover:-translate-y-0.5 hover:scale-[1.02]"
                style="background-color: var(--color-accent);"
              >
                Оставить заявку
              </a>

              <a
                href="tel:+375293326650"
                class="inline-flex items-center justify-center rounded-full border border-slate-300 px-6 py-4 text-center text-base font-semibold text-[var(--text-main)] transition duration-300 hover:border-slate-400 hover:bg-white"
              >
                Позвонить
              </a>
            </div>
          </div>
        </div>
      </div>
    </section>

    <script is:inline define:vars={{ slug: item.slug }}>
  const seoToggle = document.getElementById(`seo-toggle-${slug}`);
  const seoMore = document.getElementById(`seo-more-${slug}`);

  if (seoToggle && seoMore) {
    seoToggle.addEventListener("click", () => {
      const isHidden = seoMore.classList.contains("hidden");
      seoMore.classList.toggle("hidden");
      seoToggle.textContent = isHidden ? "Свернуть" : "Читать дальше";
    });
  }
</script>
  </main>

  <Footer />
</MainLayout>