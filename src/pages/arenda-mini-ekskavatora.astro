    >
      Читать дальше
    </button>

  </div>
</section>

<script is:inline>
  const seoToggleExcavator = document.getElementById("seo-toggle-excavator");
  const seoMoreExcavator = document.getElementById("seo-more-excavator");

  if (seoToggleExcavator && seoMoreExcavator) {
    seoToggleExcavator.addEventListener("click", () => {
      const isHidden = seoMoreExcavator.classList.contains("hidden");
      seoMoreExcavator.classList.toggle("hidden");
      seoToggleExcavator.textContent = isHidden ? "Свернуть" : "Читать дальше";
    });
  }
</script>

<section class="bg-slate-50">
  <div class="mx-auto max-w-5xl px-6 py-16 md:py-20">

