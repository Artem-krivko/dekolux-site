---
import MainLayout from "../layouts/MainLayout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";

const title = "Аренда мини-экскаватора в Могилёве — Dekolux";
const description =
  "Аренда мини-экскаватора в Могилёве и области. Траншеи, котлованы, подготовка участка, земляные работы на частных и строительных объектах.";

  const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "Для каких работ подходит мини-экскаватор?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Мини-экскаватор подходит для копки траншей, котлованов, подготовки участка, земляных работ под коммуникации и благоустройство."
      }
    },
    {
      "@type": "Question",
      "name": "Какой минимальный выезд?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Минимальный выезд зависит от типа задачи и удалённости объекта, но обычно рассчитывается от нескольких часов работы."
      }
    },
    {
      "@type": "Question",
      "name": "Можно ли использовать мини-экскаватор на частном участке?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Да, мини-экскаватор особенно удобен для частных участков, где важно аккуратно работать на ограниченном пространстве."
      }
    }
  ]
};
---

<MainLayout title={title} description={description}>
     <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
  <Header />

  <main>
    <section class="relative overflow-hidden bg-gradient-to-br from-[#0f1b30] via-[#12223c] to-[#0c1628] text-[var(--text-light)]">
      <div class="pointer-events-none absolute inset-0">
        <div class="absolute -left-20 top-10 h-72 w-72 rounded-full bg-blue-500/10 blur-3xl"></div>
        <div class="absolute right-0 top-0 h-80 w-80 rounded-full bg-orange-500/10 blur-3xl"></div>
        <div class="absolute bottom-0 left-1/3 h-64 w-64 rounded-full bg-cyan-400/5 blur-3xl"></div>
      </div>

      <div class="relative mx-auto max-w-7xl px-6 py-24 md:py-28">
        <div class="max-w-4xl">
          <div
            class="mb-6 inline-flex rounded-full border px-4 py-2 text-sm font-medium"
            style="
              border-color: color-mix(in srgb, var(--color-accent) 30%, transparent);
              background-color: color-mix(in srgb, var(--color-accent) 10%, transparent);
              color: #fed7aa;
            "
          >
            Услуга №2 • Могилёв и Могилёвская область
          </div>

          <h1 class="max-w-4xl text-4xl font-extrabold leading-[1.05] tracking-tight md:text-6xl">
            Аренда мини-экскаватора
            <span style="color: var(--color-accent);">3.5 тонны</span>
          </h1>

          <p class="mt-6 max-w-3xl text-lg leading-8 text-[var(--text-light)]/80">
            Выполняем земляные работы мини-экскаватором: траншеи, котлованы,
            планировку участка, подготовку под коммуникации и другие задачи.
            Работаем по Могилёву и области.
          </p>

          <div class="mt-10 flex flex-col gap-4 sm:flex-row">
            <a
              href="/contacts"
              class="rounded-full px-6 py-4 text-center text-base font-semibold text-white shadow-lg transition duration-300 hover:-translate-y-0.5 hover:scale-[1.02]"
              style="background-color: var(--color-accent);"
            >
              Получить расчёт
            </a>

            <a
              href="tel:+375296326650"
              class="rounded-full border border-white/15 bg-white/5 px-6 py-4 text-center text-base font-semibold text-[var(--text-light)] backdrop-blur transition duration-300 hover:border-white/30 hover:bg-white/10"
            >
              Уточнить условия аренды
            </a>
          </div>
        </div>
      </div>
    </section>

    <section class="bg-white">
      <div class="mx-auto max-w-7xl px-6 py-24 md:py-28">
        <div class="grid gap-6 md:grid-cols-3">
          <div class="rounded-3xl border border-slate-200 bg-slate-50 p-6 shadow-sm transition duration-300 hover:-translate-y-0.5 hover:shadow-md">
            <div class="text-2xl font-extrabold text-[var(--text-main)]">от 80 руб</div>
            <p class="mt-2 text-sm leading-6 text-[var(--text-muted)]">
              стоимость за час работы
            </p>
          </div>

          <div class="rounded-3xl border border-slate-200 bg-slate-50 p-6 shadow-sm transition duration-300 hover:-translate-y-0.5 hover:shadow-md">
            <div class="text-2xl font-extrabold text-[var(--text-main)]">от 4 часов</div>
            <p class="mt-2 text-sm leading-6 text-[var(--text-muted)]">
              минимальный выезд
            </p>
          </div>

          <div class="rounded-3xl border border-slate-200 bg-slate-50 p-6 shadow-sm transition duration-300 hover:-translate-y-0.5 hover:shadow-md">
            <div class="text-2xl font-extrabold text-[var(--text-main)]">3.5 тонны</div>
            <p class="mt-2 text-sm leading-6 text-[var(--text-muted)]">
              собственный мини-экскаватор
            </p>
          </div>
        </div>
      </div>
    </section>

    <section class="bg-white">
      <div class="mx-auto grid max-w-7xl gap-12 px-6 py-24 md:grid-cols-2 md:py-28">
        <div>
          <p
            class="text-sm font-semibold uppercase tracking-[0.2em]"
            style="color: var(--color-accent);"
          >
            Описание услуги
          </p>
          <h2 class="mt-4 text-3xl font-extrabold text-[var(--text-main)] md:text-5xl">
            Для каких работ подходит мини-экскаватор
          </h2>
          <p class="mt-6 max-w-3xl text-base leading-8 text-[var(--text-muted)]">
            Мини-экскаватор подходит для частных и строительных объектов, где нужна
            аккуратная и точная работа на ограниченном пространстве. Это удобное решение
            для копки траншей, котлованов, подготовки участка и других земляных работ.
          </p>
          <p class="mt-4 max-w-3xl text-base leading-8 text-[var(--text-muted)]">
            Техника особенно полезна там, где важны манёвренность, скорость и возможность
            работать без привлечения более тяжёлой техники.
          </p>
        </div>

        <div class="rounded-[2rem] border border-slate-200 bg-slate-50 p-8 shadow-sm">
          <h3 class="text-2xl font-bold text-[var(--text-main)]">Что можно выполнить</h3>

          <div class="mt-6 space-y-4">
            <div class="rounded-2xl border border-slate-200 bg-white p-5 transition duration-300 hover:-translate-y-0.5 hover:shadow-md">
              Копка траншей под воду, канализацию и кабель
            </div>
            <div class="rounded-2xl border border-slate-200 bg-white p-5 transition duration-300 hover:-translate-y-0.5 hover:shadow-md">
              Подготовка котлованов и ям
            </div>
            <div class="rounded-2xl border border-slate-200 bg-white p-5 transition duration-300 hover:-translate-y-0.5 hover:shadow-md">
              Планировка и подготовка участка
            </div>
            <div class="rounded-2xl border border-slate-200 bg-white p-5 transition duration-300 hover:-translate-y-0.5 hover:shadow-md">
              Земляные работы для частных и строительных объектов
            </div>
          </div>
        </div>
      </div>
    </section>

    <section class="bg-slate-50">
      <div class="mx-auto max-w-7xl px-6 py-24 md:py-28">
        <div class="max-w-3xl">
          <p
            class="text-sm font-semibold uppercase tracking-[0.2em]"
            style="color: var(--color-accent);"
          >
            Преимущества
          </p>
          <h2 class="mt-4 text-3xl font-extrabold text-[var(--text-main)] md:text-5xl">
            Почему арендуют технику у Dekolux
          </h2>
          <p class="mt-5 max-w-3xl text-base leading-8 text-[var(--text-muted)] md:text-lg">
            Работаем на собственной технике, быстро выезжаем по области и аккуратно
            выполняем задачи на частных и строительных объектах.
          </p>
        </div>

        <div class="mt-12 grid gap-6 md:grid-cols-2 xl:grid-cols-4">
          <div class="rounded-3xl border border-slate-200 bg-white p-6 shadow-sm transition duration-300 hover:-translate-y-0.5 hover:shadow-md">
            <h3 class="text-xl font-bold text-[var(--text-main)]">Своя техника</h3>
            <p class="mt-3 text-sm leading-6 text-[var(--text-muted)]">
              Работаем на собственном мини-экскаваторе без посредников.
            </p>
          </div>

          <div class="rounded-3xl border border-slate-200 bg-white p-6 shadow-sm transition duration-300 hover:-translate-y-0.5 hover:shadow-md">
            <h3 class="text-xl font-bold text-[var(--text-main)]">Быстрый выезд</h3>
            <p class="mt-3 text-sm leading-6 text-[var(--text-muted)]">
              Оперативно выезжаем по Могилёву и области.
            </p>
          </div>

          <div class="rounded-3xl border border-slate-200 bg-white p-6 shadow-sm transition duration-300 hover:-translate-y-0.5 hover:shadow-md">
            <h3 class="text-xl font-bold text-[var(--text-main)]">Аккуратная работа</h3>
            <p class="mt-3 text-sm leading-6 text-[var(--text-muted)]">
              Подходим к работе точно и аккуратно, особенно на частных участках.
            </p>
          </div>

          <div class="rounded-3xl border border-slate-200 bg-white p-6 shadow-sm transition duration-300 hover:-translate-y-0.5 hover:shadow-md">
            <h3 class="text-xl font-bold text-[var(--text-main)]">Удобные задачи</h3>
            <p class="mt-3 text-sm leading-6 text-[var(--text-muted)]">
              Подходит для коммуникаций, благоустройства и подготовительных работ.
            </p>
          </div>
        </div>
      </div>
    </section>

    <section class="bg-white">
      <div class="mx-auto max-w-7xl px-6 py-24 md:py-28">
        <div class="max-w-3xl">
          <p
            class="text-sm font-semibold uppercase tracking-[0.2em]"
            style="color: var(--color-accent);"
          >
            Этапы работы
          </p>
          <h2 class="mt-4 text-3xl font-extrabold text-[var(--text-main)] md:text-5xl">
            Как заказать мини-экскаватор
          </h2>
          <p class="mt-5 max-w-3xl text-base leading-8 text-[var(--text-muted)] md:text-lg">
            Делаем процесс аренды понятным: от первого обращения и уточнения задачи
            до выезда техники и выполнения работ.
          </p>
        </div>

        <div class="mt-12 grid gap-6 md:grid-cols-2 xl:grid-cols-4">
          <div class="rounded-3xl border border-slate-200 bg-white p-6 shadow-sm transition duration-300 hover:-translate-y-0.5 hover:shadow-md">
            <div class="text-sm font-semibold" style="color: var(--color-accent);">01</div>
            <h3 class="mt-3 text-lg font-bold text-[var(--text-main)]">Заявка</h3>
            <p class="mt-2 text-sm leading-6 text-[var(--text-muted)]">
              Вы звоните или оставляете заявку.
            </p>
          </div>

          <div class="rounded-3xl border border-slate-200 bg-white p-6 shadow-sm transition duration-300 hover:-translate-y-0.5 hover:shadow-md">
            <div class="text-sm font-semibold" style="color: var(--color-accent);">02</div>
            <h3 class="mt-3 text-lg font-bold text-[var(--text-main)]">Уточнение задачи</h3>
            <p class="mt-2 text-sm leading-6 text-[var(--text-muted)]">
              Обсуждаем объём работ, сроки и место.
            </p>
          </div>

          <div class="rounded-3xl border border-slate-200 bg-white p-6 shadow-sm transition duration-300 hover:-translate-y-0.5 hover:shadow-md">
            <div class="text-sm font-semibold" style="color: var(--color-accent);">03</div>
            <h3 class="mt-3 text-lg font-bold text-[var(--text-main)]">Выезд техники</h3>
            <p class="mt-2 text-sm leading-6 text-[var(--text-muted)]">
              Приезжаем на объект в согласованное время.
            </p>
          </div>

          <div class="rounded-3xl border border-slate-200 bg-white p-6 shadow-sm transition duration-300 hover:-translate-y-0.5 hover:shadow-md">
            <div class="text-sm font-semibold" style="color: var(--color-accent);">04</div>
            <h3 class="mt-3 text-lg font-bold text-[var(--text-main)]">Выполнение работ</h3>
            <p class="mt-2 text-sm leading-6 text-[var(--text-muted)]">
              Выполняем работы аккуратно и по задаче.
            </p>
          </div>
        </div>
      </div>
    </section>

    <section class="text-[var(--text-light)]" style="background-color: var(--color-brand);">
      <div class="mx-auto max-w-7xl px-6 py-24 md:py-28">
        <div class="relative overflow-hidden rounded-[2rem] border border-slate-800 bg-slate-900 p-8 md:p-12">
          <div
            class="pointer-events-none absolute inset-0 opacity-70"
            style="background: radial-gradient(circle at top right, color-mix(in srgb, var(--color-accent) 22%, transparent), transparent 40%);"
          ></div>

          <div class="relative max-w-3xl">
            <h2 class="text-3xl font-extrabold md:text-4xl">
              Нужен мини-экскаватор в Могилёве или области?
            </h2>
            <p class="mt-4 max-w-2xl text-base leading-8 text-[var(--text-light)]/80">
              Напишите или позвоните нам — поможем оценить объём работ и подскажем
              подходящий формат выезда.
            </p>

            <div class="mt-8 flex flex-col gap-4 sm:flex-row">
              <a
                href="/contacts"
                class="rounded-full px-6 py-4 text-center text-base font-semibold text-white transition duration-300 hover:-translate-y-0.5 hover:scale-[1.02]"
                style="background-color: var(--color-accent);"
              >
                Получить расчёт
              </a>

              <a
                href="tel:+375296326650"
                class="rounded-full border border-slate-700 px-6 py-4 text-center text-base font-semibold text-[var(--text-light)] transition duration-300 hover:border-slate-500 hover:bg-slate-800"
              >
                Позвонить
              </a>
            </div>
          </div>
        </div>
      </div>
    </section>
  </main>

  <section class="bg-white">
  <div class="mx-auto max-w-4xl px-6 py-20">
    <h2 class="text-2xl font-bold text-[var(--text-main)] md:text-3xl">
      Частые вопросы по аренде мини-экскаватора
    </h2>

    <div class="mt-8 space-y-4">
      <div class="rounded-2xl border border-slate-200 bg-slate-50 p-6">
        <h3 class="text-lg font-bold text-[var(--text-main)]">
          Для каких работ подходит мини-экскаватор?
        </h3>
        <p class="mt-3 text-base leading-8 text-[var(--text-muted)]">
          Мини-экскаватор подходит для копки траншей, котлованов, подготовки участка,
          земляных работ под коммуникации и благоустройство.
        </p>
      </div>

      <div class="rounded-2xl border border-slate-200 bg-slate-50 p-6">
        <h3 class="text-lg font-bold text-[var(--text-main)]">
          Какой минимальный выезд?
        </h3>
        <p class="mt-3 text-base leading-8 text-[var(--text-muted)]">
          Минимальный выезд зависит от типа задачи и удалённости объекта,
          но обычно рассчитывается от нескольких часов работы.
        </p>
      </div>

      <div class="rounded-2xl border border-slate-200 bg-slate-50 p-6">
        <h3 class="text-lg font-bold text-[var(--text-main)]">
          Можно ли использовать мини-экскаватор на частном участке?
        </h3>
        <p class="mt-3 text-base leading-8 text-[var(--text-muted)]">
          Да, мини-экскаватор особенно удобен для частных участков, где важно аккуратно работать
          на ограниченном пространстве.
        </p>
      </div>
    </div>
  </div>
</section>

  <section class="bg-slate-50 py-20">
  <div class="mx-auto max-w-4xl px-6">

    <h2 class="text-2xl font-bold mb-6">
      Аренда мини-экскаватора в Могилёве
    </h2>

    <p class="text-lg leading-8 text-slate-600 mb-6">
      Мини-экскаватор — удобная техника для выполнения земляных работ
      на частных участках и строительных объектах. С его помощью можно
      быстро копать траншеи под коммуникации, готовить котлованы,
      выполнять планировку участка и другие работы.
    </p>

    <p class="text-lg leading-8 text-slate-600 mb-6">
      Компания Dekolux предлагает аренду мини-экскаватора в Могилёве
      и Могилёвской области. Мы работаем на собственной технике,
      обеспечиваем аккуратное выполнение работ и выезд на объект
      в удобное для клиента время.
    </p>
    <p class="text-lg leading-8 text-slate-600 mb-6">
  Мини-экскаватор часто используется для подготовки траншей
  перед выполнением
  <a href="/gnb-prokol" class="text-[var(--color-accent)] hover:underline">
    прокола под дорогой методом ГНБ
  </a>.
</p>

<p class="text-lg leading-8 text-slate-600">
  Также техника применяется при
  <a href="/kanalizaciya-septiki" class="text-[var(--color-accent)] hover:underline">
    монтаже наружной канализации и септиков
  </a>
  на частных участках.
</p>

  </div>
</section>

  <Footer />
</MainLayout>