---
import MainLayout from "../layouts/MainLayout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";

const title = "Аренда мини-экскаватора в Могилёве — с оператором | цены и выезд";
const description =
  "Аренда мини-экскаватора в Могилёве и области. Земляные работы, траншеи, планировка участка. Работаем быстро, своя техника. Звоните.";

  const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "Для каких работ подходит мини-экскаватор?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Мини-экскаватор подходит для копки траншей, котлованов, подготовки участка, земляных работ под коммуникации и благоустройство."
      }
    },
    {
      "@type": "Question",
      "name": "Какой минимальный выезд?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Минимальный выезд зависит от типа задачи и удалённости объекта, но обычно рассчитывается от нескольких часов работы."
      }
    },
    {
      "@type": "Question",
      "name": "Можно ли использовать мини-экскаватор на частном участке?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Да, мини-экскаватор особенно удобен для частных участков, где важно аккуратно работать на ограниченном пространстве."
      }
    }
  ]
};
const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: [
    {
      "@type": "ListItem",
      position: 1,
      name: "Главная",
      item: "https://www.dekolux.by/"
    },
    {
      "@type": "ListItem",
      position: 2,
      name: "Аренда мини-экскаватора",
      item: "https://www.dekolux.by/arenda-mini-ekskavatora"
    }
  ]
};
---

<MainLayout title={title} description={description}>
     <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
  <Header />
  <nav class="mx-auto max-w-7xl px-6 pt-6 text-sm text-slate-500">
  <a href="/" class="hover:text-slate-700">Главная</a>
  <span class="mx-2">/</span>
  <span class="text-slate-700">Аренда мини-экскаватора</span>
</nav>

  <main>
    <section class="relative overflow-hidden bg-gradient-to-br from-[#0f1b30] via-[#12223c] to-[#0c1628] text-[var(--text-light)]">
