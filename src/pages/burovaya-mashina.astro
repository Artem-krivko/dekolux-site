  <script is:inline>
    const seoToggleDrillMachine = document.getElementById("seo-toggle-drill-machine");
    const seoMoreDrillMachine = document.getElementById("seo-more-drill-machine");

    if (seoToggleDrillMachine && seoMoreDrillMachine) {
      seoToggleDrillMachine.addEventListener("click", () => {
        const isHidden = seoMoreDrillMachine.classList.contains("hidden");
        seoMoreDrillMachine.classList.toggle("hidden");
        seoToggleDrillMachine.textContent = isHidden ? "Свернуть" : "Читать дальше";
      });
    }
