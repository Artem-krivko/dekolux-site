  <script is:inline>
    const seoToggleWheeled = document.getElementById("seo-toggle-wheeled");
    const seoMoreWheeled = document.getElementById("seo-more-wheeled");

    if (seoToggleWheeled && seoMoreWheeled) {
      seoToggleWheeled.addEventListener("click", () => {
        const isHidden = seoMoreWheeled.classList.contains("hidden");
        seoMoreWheeled.classList.toggle("hidden");
        seoToggleWheeled.textContent = isHidden ? "Свернуть" : "Читать дальше";
      });
    }
