---
import MainLayout from "../layouts/MainLayout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";

const title = "Аренда колесного экскаватора в Могилёве — с оператором | Dekolux";
const description =
  "Аренда колесного экскаватора в Могилёве и области. Земляные работы большого объёма, разработка грунта, погрузка. Собственная техника, быстрый выезд.";

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "Чем колесный экскаватор отличается от гусеничного?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Колесный экскаватор более мобилен, может самостоятельно перемещаться по дорогам без транспортировки на трале. Это ускоряет выезд и удешевляет доставку на объект."
      }
    },
    {
      "@type": "Question",
      "name": "Для каких работ подходит колесный экскаватор?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Колесный экскаватор подходит для разработки грунта, копки траншей большого объёма, погрузки материалов, планировки участков и строительных работ."
      }
    },
    {
      "@type": "Question",
      "name": "Какова минимальная аренда колесного экскаватора?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Минимальный выезд — от 4 часов. Стоимость зависит от объёма и сложности работ, а также удалённости объекта."
      }
    }
  ]
};

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: [
    {
      "@type": "ListItem",
      position: 1,
      name: "Главная",
      item: "https://www.dekolux.by/"
    },
    {
      "@type": "ListItem",
      position: 2,
      name: "Аренда колесного экскаватора",
      item: "https://www.dekolux.by/arenda-kolesnogo-ekskavatora"
    }
  ]
};
---

<MainLayout title={title} description={description}>
  <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
  <Header />

  <nav class="mx-auto max-w-7xl px-6 pt-6 text-sm text-slate-500">
    <a href="/" class="hover:text-slate-700">Главная</a>
    <span class="mx-2">/</span>
    <span class="text-slate-700">Аренда колесного экскаватора</span>
  </nav>

  <main>
    <section class="relative overflow-hidden bg-gradient-to-br from-[#0f1b30] via-[#12223c] to-[#0c1628] text-[var(--text-light)]">
      <div class="pointer-events-none absolute inset-0">
        <div class="absolute -left-20 top-10 h-72 w-72 rounded-full bg-blue-500/10 blur-3xl"></div>
        <div class="absolute right-0 top-0 h-80 w-80 rounded-full bg-orange-500/10 blur-3xl"></div>
        <div class="absolute bottom-0 left-1/3 h-64 w-64 rounded-full bg-cyan-400/5 blur-3xl"></div>
      </div>

      <div class="relative mx-auto max-w-7xl px-6 py-24 md:py-28">
        <div class="max-w-4xl">
          <div
            class="mb-6 inline-flex rounded-full border px-4 py-2 text-sm font-medium"
            style="
              border-color: color-mix(in srgb, var(--color-accent) 30%, transparent);
              background-color: color-mix(in srgb, var(--color-accent) 10%, transparent);
              color: #fed7aa;
            "
          >
            Услуга №4 • Могилёв и Могилёвская область
          </div>
        </div>
        <h1 class="max-w-4xl text-4xl font-extrabold leading-[1.05] tracking-tight md:text-6xl">
          Аренда колесного экскаватора в Могилёве
          <span style="color: var(--color-accent);">с оператором</span>
        </h1>

        <p class="mt-6 max-w-3xl text-lg leading-8 text-[var(--text-light)]/80">
          Земляные работы большого объёма, разработка грунта и погрузка на строительных объектах.
          Собственная техника, быстрый выезд по Могилёву и области.
        </p>

        <div class="mt-10 flex flex-col gap-4 sm:flex-row">
          <a
            href="/contacts"
            class="rounded-full px-6 py-4 text-center text-base font-semibold text-white shadow-lg transition duration-300 hover:-translate-y-0.5 hover:scale-[1.02]"
            style="background-color: var(--color-accent);"
          >
            Получить расчёт
          </a>

          <a
            href="tel:+375293326650"
            class="rounded-full border border-white/15 bg-white/5 px-6 py-4 text-center text-base font-semibold text-[var(--text-light)] backdrop-blur transition duration-300 hover:border-white/30 hover:bg-white/10"
          >
            Уточнить условия аренды
          </a>
        </div>
      </div>
    </section>

    <section class="bg-white">
      <div class="mx-auto max-w-7xl px-6 py-24 md:py-28">
        <div class="grid gap-6 md:grid-cols-3">
          <div class="rounded-3xl border border-slate-200 bg-slate-50 p-6 shadow-sm transition duration-300 hover:-translate-y-0.5 hover:shadow-md">
            <div class="text-2xl font-extrabold text-[var(--text-main)]">от 70 руб</div>
            <p class="mt-2 text-sm leading-6 text-[var(--text-muted)]">стоимость за час работы</p>
          </div>

          <div class="rounded-3xl border border-slate-200 bg-slate-50 p-6 shadow-sm transition duration-300 hover:-translate-y-0.5 hover:shadow-md">
            <div class="text-2xl font-extrabold text-[var(--text-main)]">от 4 часов</div>
            <p class="mt-2 text-sm leading-6 text-[var(--text-muted)]">минимальный выезд</p>
          </div>

          <div class="rounded-3xl border border-slate-200 bg-slate-50 p-6 shadow-sm transition duration-300 hover:-translate-y-0.5 hover:shadow-md">
            <div class="text-2xl font-extrabold text-[var(--text-main)]">Большой объём</div>
            <p class="mt-2 text-sm leading-6 text-[var(--text-muted)]">для крупных земляных работ</p>
          </div>
        </div>
      </div>
    </section>

    <section class="bg-white">
      <div class="mx-auto grid max-w-7xl gap-12 px-6 py-24 md:grid-cols-2 md:py-28">
        <div>
          <p
            class="text-sm font-semibold uppercase tracking-[0.2em]"
            style="color: var(--color-accent);"
          >
            Описание услуги
          </p>
          <h2 class="mt-4 text-3xl font-extrabold text-[var(--text-main)] md:text-5xl">
            Для каких работ подходит колесный экскаватор
          </h2>
          <p class="mt-6 max-w-3xl text-base leading-8 text-[var(--text-muted)]">
            Колесный экскаватор — это мощная и мобильная техника для выполнения
            земляных работ большого объёма. В отличие от гусеничной техники, он может
            самостоятельно перемещаться по дорогам, что ускоряет выезд на объект.
          </p>
          <p class="mt-4 max-w-3xl text-base leading-8 text-[var(--text-muted)]">
            Особенно востребован на строительных объектах, при прокладке коммуникаций,
            разработке котлованов и при работах, требующих высокой производительности.
          </p>
        </div>

        <div class="rounded-[2rem] border border-slate-200 bg-slate-50 p-8 shadow-sm">
          <h3 class="text-2xl font-bold text-[var(--text-main)]">Что можно выполнить</h3>

          <div class="mt-6 space-y-4">
            <div class="rounded-2xl border border-slate-200 bg-white p-5 transition duration-300 hover:-translate-y-0.5 hover:shadow-md">
              Разработка грунта и копка котлованов большого объёма
            </div>
            <div class="rounded-2xl border border-slate-200 bg-white p-5 transition duration-300 hover:-translate-y-0.5 hover:shadow-md">
              Прокладка траншей под коммуникации
            </div>
            <div class="rounded-2xl border border-slate-200 bg-white p-5 transition duration-300 hover:-translate-y-0.5 hover:shadow-md">
              Погрузка и перемещение грунта и материалов
            </div>
            <div class="rounded-2xl border border-slate-200 bg-white p-5 transition duration-300 hover:-translate-y-0.5 hover:shadow-md">
              Планировка и подготовка строительных площадок
            </div>
          </div>
        </div>
      </div>
    </section>

    <section class="bg-slate-50">
      <div class="mx-auto max-w-7xl px-6 py-24 md:py-28">
        <div class="max-w-3xl">
          <p
            class="text-sm font-semibold uppercase tracking-[0.2em]"
            style="color: var(--color-accent);"
          >
            Преимущества
          </p>
          <h2 class="mt-4 text-3xl font-extrabold text-[var(--text-main)] md:text-5xl">
            Почему выбирают колесный экскаватор Dekolux
          </h2>
          <p class="mt-5 max-w-3xl text-base leading-8 text-[var(--text-muted)] md:text-lg">
            Собственная техника, оперативный выезд и опытный оператор — для любых
            земляных работ в Могилёве и области.
          </p>
        </div>

        <div class="mt-12 grid gap-6 md:grid-cols-2 xl:grid-cols-4">
          <div class="rounded-3xl border border-slate-200 bg-white p-6 shadow-sm transition duration-300 hover:-translate-y-0.5 hover:shadow-md">
            <h3 class="text-xl font-bold text-[var(--text-main)]">Высокая мощность</h3>
            <p class="mt-3 text-sm leading-6 text-[var(--text-muted)]">
              Справляется с большими объёмами грунтовых работ за короткое время.
            </p>
          </div>

          <div class="rounded-3xl border border-slate-200 bg-white p-6 shadow-sm transition duration-300 hover:-translate-y-0.5 hover:shadow-md">
            <h3 class="text-xl font-bold text-[var(--text-main)]">Мобильность</h3>
            <p class="mt-3 text-sm leading-6 text-[var(--text-muted)]">
              Колесный экскаватор самостоятельно добирается до объекта без трала.
            </p>
          </div>

          <div class="rounded-3xl border border-slate-200 bg-white p-6 shadow-sm transition duration-300 hover:-translate-y-0.5 hover:shadow-md">
            <h3 class="text-xl font-bold text-[var(--text-main)]">Опытный оператор</h3>
            <p class="mt-3 text-sm leading-6 text-[var(--text-muted)]">
              Работаем аккуратно и точно, с вниманием к условиям объекта.
            </p>
          </div>

          <div class="rounded-3xl border border-slate-200 bg-white p-6 shadow-sm transition duration-300 hover:-translate-y-0.5 hover:shadow-md">
            <h3 class="text-xl font-bold text-[var(--text-main)]">Своя техника</h3>
            <p class="mt-3 text-sm leading-6 text-[var(--text-muted)]">
              Без посредников — быстрее и дешевле для заказчика.
            </p>
          </div>
        </div>
      </div>
    </section>

    <section class="bg-white">
      <div class="mx-auto max-w-7xl px-6 py-24 md:py-28">
        <div class="max-w-3xl">
          <p
            class="text-sm font-semibold uppercase tracking-[0.2em]"
            style="color: var(--color-accent);"
          >
            Этапы работы
          </p>
          <h2 class="mt-4 text-3xl font-extrabold text-[var(--text-main)] md:text-5xl">
            Как заказать колесный экскаватор
          </h2>
          <p class="mt-5 max-w-3xl text-base leading-8 text-[var(--text-muted)] md:text-lg">
            Простой процесс от заявки до выезда техники на объект.
          </p>
        </div>

        <div class="mt-12 grid gap-6 md:grid-cols-2 xl:grid-cols-4">
          <div class="rounded-3xl border border-slate-200 bg-white p-6 shadow-sm transition duration-300 hover:-translate-y-0.5 hover:shadow-md">
            <div class="text-sm font-semibold" style="color: var(--color-accent);">01</div>
            <h3 class="mt-3 text-lg font-bold text-[var(--text-main)]">Заявка</h3>
            <p class="mt-2 text-sm leading-6 text-[var(--text-muted)]">
              Вы звоните или оставляете заявку на сайте.
            </p>
          </div>

          <div class="rounded-3xl border border-slate-200 bg-white p-6 shadow-sm transition duration-300 hover:-translate-y-0.5 hover:shadow-md">
            <div class="text-sm font-semibold" style="color: var(--color-accent);">02</div>
            <h3 class="mt-3 text-lg font-bold text-[var(--text-main)]">Уточнение задачи</h3>
            <p class="mt-2 text-sm leading-6 text-[var(--text-muted)]">
              Обсуждаем объём работ, место и сроки.
            </p>
          </div>

          <div class="rounded-3xl border border-slate-200 bg-white p-6 shadow-sm transition duration-300 hover:-translate-y-0.5 hover:shadow-md">
            <div class="text-sm font-semibold" style="color: var(--color-accent);">03</div>
            <h3 class="mt-3 text-lg font-bold text-[var(--text-main)]">Выезд техники</h3>
            <p class="mt-2 text-sm leading-6 text-[var(--text-muted)]">
              Приезжаем на объект в согласованное время.
            </p>
          </div>

          <div class="rounded-3xl border border-slate-200 bg-white p-6 shadow-sm transition duration-300 hover:-translate-y-0.5 hover:shadow-md">
            <div class="text-sm font-semibold" style="color: var(--color-accent);">04</div>
            <h3 class="mt-3 text-lg font-bold text-[var(--text-main)]">Выполнение работ</h3>
            <p class="mt-2 text-sm leading-6 text-[var(--text-muted)]">
              Выполняем работы в срок и с нужным результатом.
            </p>
          </div>
        </div>
      </div>
    </section>

    <section class="text-[var(--text-light)]" style="background-color: var(--color-brand);">
      <div class="mx-auto max-w-7xl px-6 py-24 md:py-28">
        <div class="relative overflow-hidden rounded-[2rem] border border-slate-800 bg-slate-900 p-8 md:p-12">
          <div
            class="pointer-events-none absolute inset-0 opacity-70"
            style="background: radial-gradient(circle at top right, color-mix(in srgb, var(--color-accent) 22%, transparent), transparent 40%);"
          ></div>

          <div class="relative max-w-3xl">
            <h2 class="text-3xl font-extrabold md:text-4xl">
              Нужен колесный экскаватор в Могилёве или области?
            </h2>
            <p class="mt-4 max-w-2xl text-base leading-8 text-[var(--text-light)]/80">
              Напишите или позвоните — поможем оценить объём работ и подберём
              оптимальный формат выезда.
            </p>

            <div class="mt-8 flex flex-col gap-4 sm:flex-row">
              <a
                href="/contacts"
                class="rounded-full px-6 py-4 text-center text-base font-semibold text-white transition duration-300 hover:-translate-y-0.5 hover:scale-[1.02]"
                style="background-color: var(--color-accent);"
              >
                Получить расчёт
              </a>

              <a
                href="tel:+375293326650"
                class="rounded-full border border-slate-700 px-6 py-4 text-center text-base font-semibold text-[var(--text-light)] transition duration-300 hover:border-slate-500 hover:bg-slate-800"
              >
                Позвонить
              </a>
            </div>
          </div>
        </div>
      </div>
    </section>
  </main>

  <section class="bg-white">
    <div class="mx-auto max-w-4xl px-6 py-20">
      <h2 class="text-2xl font-bold text-[var(--text-main)] md:text-3xl">
        Частые вопросы по аренде колесного экскаватора
      </h2>

      <div class="mt-8 space-y-4">
        <details class="group rounded-2xl border border-slate-200 bg-slate-50 p-6">
          <summary class="flex cursor-pointer list-none items-center justify-between gap-4 text-lg font-bold text-[var(--text-main)]">
            <span>Чем колесный экскаватор отличается от гусеничного?</span>
            <span class="text-2xl text-[var(--color-accent)] transition group-open:rotate-45">+</span>
          </summary>
          <p class="mt-4 text-base leading-8 text-[var(--text-muted)]">
            Колесный экскаватор более мобилен — он самостоятельно перемещается по дорогам
            без транспортировки на трале, что ускоряет выезд и снижает стоимость доставки.
          </p>
        </details>

        <details class="group rounded-2xl border border-slate-200 bg-slate-50 p-6">
          <summary class="flex cursor-pointer list-none items-center justify-between gap-4 text-lg font-bold text-[var(--text-main)]">
            <span>Для каких работ подходит колесный экскаватор?</span>
            <span class="text-2xl text-[var(--color-accent)] transition group-open:rotate-45">+</span>
          </summary>
          <p class="mt-4 text-base leading-8 text-[var(--text-muted)]">
            Разработка грунта, копка траншей и котлованов большого объёма, погрузка материалов,
            планировка строительных площадок и подготовка участков.
          </p>
        </details>

        <details class="group rounded-2xl border border-slate-200 bg-slate-50 p-6">
          <summary class="flex cursor-pointer list-none items-center justify-between gap-4 text-lg font-bold text-[var(--text-main)]">
            <span>Какова минимальная аренда?</span>
            <span class="text-2xl text-[var(--color-accent)] transition group-open:rotate-45">+</span>
          </summary>
          <p class="mt-4 text-base leading-8 text-[var(--text-muted)]">
            Минимальный выезд — от 4 часов. Стоимость зависит от объёма работ,
            сложности объекта и удалённости от Могилёва.
          </p>
        </details>
      </div>
    </div>
  </section>

  <section class="bg-slate-50 py-20">
    <div class="mx-auto max-w-4xl px-6">
      <h2 class="mb-6 text-2xl font-bold text-[var(--text-main)]">
        Аренда колесного экскаватора в Могилёве
      </h2>

      <div class="space-y-6 text-lg leading-8 text-slate-600">
        <p>
          Колесный экскаватор — это универсальная техника для земляных работ
          большого объёма. Подходит для копки котлованов, траншей, погрузки
          и планировки территорий на строительных объектах.
        </p>

        <div id="seo-more-wheeled" class="hidden space-y-6 md:block">
          <p>
            Компания Dekolux предлагает аренду колесного экскаватора в Могилёве
            и Могилёвской области с опытным оператором. Работаем на собственной технике —
            без посредников и с быстрым выездом.
          </p>

          <p>
            Колесный экскаватор часто используется в комплексе с другими услугами:
            <a href="/arenda-mini-ekskavatora" class="text-orange-500 hover:underline">
              аренда мини-экскаватора
            </a>
            для работ в ограниченном пространстве, или
            <a href="/kanalizaciya-septiki" class="text-orange-500 hover:underline">
              монтаж канализации и септиков
            </a>
            после разработки котлована.
          </p>

          <p>
            Также мы выполняем
            <a href="/gnb-prokol" class="text-orange-500 hover:underline">
              прокол под дорогой методом ГНБ
            </a>
            и
            <a href="/burenie-skvazhin" class="text-orange-500 hover:underline">
              бурение скважин на воду
            </a>
            в Могилёве и области.
          </p>
        </div>
      </div>

      <button
        id="seo-toggle-wheeled"
        type="button"
        class="mt-6 inline-flex rounded-full border border-slate-300 px-5 py-3 text-sm font-semibold text-[var(--text-main)] transition hover:border-slate-400 hover:bg-white md:hidden"
      >
        Читать дальше
      </button>
    </div>
  </section>

  <section class="bg-slate-50">
    <div class="mx-auto max-w-5xl px-6 py-16 md:py-20">
      <div class="rounded-[2rem] border border-slate-200 bg-white p-6 shadow-sm sm:p-8 md:p-10">
        <p class="text-sm font-semibold uppercase tracking-[0.2em]" style="color: var(--color-accent);">
          Полезная информация
        </p>

        <h2 class="mt-4 text-3xl font-extrabold text-[var(--text-main)] md:text-4xl">
          Аренда колесного экскаватора в Могилёве и области
        </h2>

        <p class="mt-5 text-base leading-8 text-[var(--text-muted)] md:text-lg">
          Колесный экскаватор незаменим там, где нужна высокая производительность и
          мобильность. Техника самостоятельно перемещается между объектами, что снижает
          затраты на транспортировку и ускоряет начало работ.
        </p>

        <h3 class="mt-8 text-2xl font-bold text-[var(--text-main)]">
          Когда нужна аренда колесного экскаватора
        </h3>

        <ul class="mt-4 space-y-3 text-base leading-8 text-[var(--text-muted)] md:text-lg">
          <li>• разработка котлованов и траншей большого объёма</li>
          <li>• погрузка грунта и строительных материалов</li>
          <li>• подготовка строительных площадок</li>
          <li>• земляные работы на дорожных и инженерных объектах</li>
        </ul>

        <h3 class="mt-8 text-2xl font-bold text-[var(--text-main)]">
          Преимущества колесного экскаватора
