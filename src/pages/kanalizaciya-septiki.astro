---
import MainLayout from "../layouts/MainLayout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";

const title = "Наружная канализация и монтаж септиков в Могилёве — Dekolux";
const description =
  "Наружная канализация и монтаж септиков в Могилёве и области. Копка траншей, укладка труб, подготовка участка, установка септиков под ключ.";
  const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "Что входит в монтаж наружной канализации?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Обычно работы включают подготовку участка, копку траншей, укладку труб, монтаж септика и подключение системы."
      }
    },
    {
      "@type": "Question",
      "name": "Можно ли заказать канализацию и септик под ключ?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Да, мы выполняем комплекс работ: от земляных работ и подготовки участка до монтажа системы и установки септика."
      }
    },
    {
      "@type": "Question",
      "name": "От чего зависит стоимость монтажа септика?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Стоимость зависит от типа септика, объёма земляных работ, длины трубопровода, особенностей участка и уровня подготовки основания."
      }
    }
  ]
};
const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: [
    {
      "@type": "ListItem",
      position: 1,
      name: "Главная",
      item: "https://dekolux.by/"
    },
    {
      "@type": "ListItem",
      position: 2,
      name: "Канализация и септики",
      item: "https://dekolux.by/kanalizaciya-septiki"
    }
  ]
};

---

<MainLayout title={title} description={description}>
     <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
  <Header />
  <nav class="mx-auto max-w-7xl px-6 pt-6 text-sm text-slate-500">
  <a href="/" class="hover:text-slate-700">Главная</a>
  <span class="mx-2">/</span>
  <span class="text-slate-700">Канализация и септики</span>
</nav>

  <main>
    <section class="relative overflow-hidden bg-gradient-to-br from-[#0f1b30] via-[#12223c] to-[#0c1628] text-[var(--text-light)]">
      <div class="pointer-events-none absolute inset-0">
        <div class="absolute -left-20 top-10 h-72 w-72 rounded-full bg-blue-500/10 blur-3xl"></div>
        <div class="absolute right-0 top-0 h-80 w-80 rounded-full bg-orange-500/10 blur-3xl"></div>
        <div class="absolute bottom-0 left-1/3 h-64 w-64 rounded-full bg-cyan-400/5 blur-3xl"></div>
      </div>

      <div class="relative mx-auto max-w-7xl px-6 py-24 md:py-28">
        <div class="max-w-4xl">
          <div
            class="mb-6 inline-flex rounded-full border px-4 py-2 text-sm font-medium"
            style="
              border-color: color-mix(in srgb, var(--color-accent) 30%, transparent);
              background-color: color-mix(in srgb, var(--color-accent) 10%, transparent);
              color: #fed7aa;
            "
          >
            Услуга №3 • Могилёв и Могилёвская область
          </div>

          <h1 class="max-w-4xl text-4xl font-extrabold leading-[1.05] tracking-tight md:text-6xl">
            Наружная канализация
            <span style="color: var(--color-accent);">и монтаж септиков</span>
          </h1>

          <p class="mt-6 max-w-3xl text-lg leading-8 text-[var(--text-light)]/80">
            Выполняем наружную канализацию и монтаж септиков для частных домов и
            объектов. Подготовим участок, выполним земляные работы, уложим трубы и
            поможем реализовать систему под ключ.
          </p>

          <div class="mt-10 flex flex-col gap-4 sm:flex-row">
            <a
              href="/contacts"
              class="rounded-full px-6 py-4 text-center text-base font-semibold text-white shadow-lg transition duration-300 hover:-translate-y-0.5 hover:scale-[1.02]"
              style="background-color: var(--color-accent);"
            >
              Получить расчёт
            </a>

            <a
              href="tel:+375293326650"
              class="rounded-full border border-white/15 bg-white/5 px-6 py-4 text-center text-base font-semibold text-[var(--text-light)] backdrop-blur transition duration-300 hover:border-white/30 hover:bg-white/10"
            >
              Обсудить задачу
            </a>
          </div>
        </div>
      </div>
    </section>

    <section class="bg-white">
      <div class="mx-auto max-w-7xl px-6 py-24 md:py-28">
        <div class="grid gap-6 md:grid-cols-3">
          <div class="rounded-3xl border border-slate-200 bg-slate-50 p-6 shadow-sm transition duration-300 hover:-translate-y-0.5 hover:shadow-md">
            <div class="text-2xl font-extrabold text-[var(--text-main)]">Под ключ</div>
            <p class="mt-2 text-sm leading-6 text-[var(--text-muted)]">
              от земляных работ до укладки труб
            </p>
          </div>

          <div class="rounded-3xl border border-slate-200 bg-slate-50 p-6 shadow-sm transition duration-300 hover:-translate-y-0.5 hover:shadow-md">
            <div class="text-2xl font-extrabold text-[var(--text-main)]">Своя техника</div>
            <p class="mt-2 text-sm leading-6 text-[var(--text-muted)]">
              мини-экскаватор и техника для работ на участке
            </p>
          </div>

          <div class="rounded-3xl border border-slate-200 bg-slate-50 p-6 shadow-sm transition duration-300 hover:-translate-y-0.5 hover:shadow-md">
            <div class="text-2xl font-extrabold text-[var(--text-main)]">Могилёв и область</div>
            <p class="mt-2 text-sm leading-6 text-[var(--text-muted)]">
              выезжаем на частные и строительные объекты
