---
import MainLayout from "../layouts/MainLayout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";

const title = "Прокол под дорогой и ГНБ в Могилёве — Dekolux";
const description =
  "Прокол под дорогой и горизонтально направленное бурение в Могилёве и области. Прокладка коммуникаций без вскрытия покрытия, собственная техника, быстрый выезд.";

  const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "Что такое прокол под дорогой?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Это способ прокладки коммуникаций под дорогой без вскрытия асфальта и разрушения покрытия. Чаще всего для этого используется метод горизонтально направленного бурения."
      }
    },
    {
      "@type": "Question",
      "name": "Можно ли сделать прокол без вскрытия асфальта?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Да, именно в этом и заключается главное преимущество ГНБ: коммуникации прокладываются под дорогой без демонтажа покрытия."
      }
    },
    {
      "@type": "Question",
      "name": "От чего зависит стоимость прокола под дорогой?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Стоимость зависит от длины прокола, типа грунта, диаметра коммуникаций, условий на объекте и особенностей подъезда техники."
      }
    }
  ]
};
const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: [
    {
      "@type": "ListItem",
      position: 1,
      name: "Главная",
      item: "https://dekolux.by/"
    },
    {
      "@type": "ListItem",
      position: 2,
      name: "Прокол под дорогой",
      item: "https://dekolux.by/gnb-prokol"
    }
  ]
};
---

<MainLayout title={title} description={description}>
    <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
  <Header />
  <nav class="mx-auto max-w-7xl px-6 pt-6 text-sm text-slate-500">
  <a href="/" class="hover:text-slate-700">Главная</a>
